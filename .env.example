# Copy to .env and set your values
SPREADSHEET_ID=your_google_sheet_id
SHEET_NAME=Sheet1

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Your Telegram user ID (optional - if set, only you can use the bot)
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=your_user_id

# Google Service Account credentials (JSON string)
# Or place credentials.json in the root directory
GOOGLE_CREDENTIALS={"type":"service_account",...}

# Queue settings
QUEUE_FILE=./data/expense-queue.jsonl
FLUSH_INTERVAL_MS=30000
FLUSH_MAX_ATTEMPTS=6